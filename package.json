{
    "version": "3.1.1",
    "name": "@20syldev/cdn",
    "description": "Self-hosted CDN API to store, version and distribute scripts and packages",
    "main": "dist/app.js",
    "type": "module",
    "scripts": {
        "dev": "tsx watch src/app.ts",
        "start": "node dist/app.js",
        "build": "tsc",
        "fetch": "bash scripts/fetch.sh",
        "check": "tsc --noEmit && eslint src/",
        "format": "prettier --write src/ && eslint --fix src/",
        "upgrade:minor": "npm upgrade",
        "upgrade:major": "npx npm-check-updates -u && npm install"
    },
    "dependencies": {
        "@20syldev/logger.ts": "^1.0.1",
        "cors": "latest",
        "express": "latest"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/node": "^25.5.0",
        "eslint": "^10.1.0",
        "eslint-config-prettier": "^10.1.8",
        "npm-check-updates": "latest",
        "prettier": "^3.8.1",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.57.2"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/20syldev/cdn.git"
    },
    "keywords": [
        "cdn",
        "express",
        "utility"
    ],
    "author": "Sylvain L.",
    "license": "BSD 3-Clause",
    "bugs": {
        "url": "https://github.com/20syldev/cdn/issues"
    },
    "homepage": "https://cdn.sylvain.sh"
}
